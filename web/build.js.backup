  { slug: "about", title: `About ${BRAND}`, h1: `About ${BRAND}`,
    kicker: "A minimalist, ad-free YouTube converter focused on speed, clarity, and privacy.",
    defaultFormat: "mp3", defaultQuality: "320",
    keywords: "about ytmp3, youtube converter about",
    sections: [
      ["Why we built this", `Most YouTube converters are buried in pop-ups, redirect chains, and fake download buttons. We wanted something that does one job — link in, file out — with zero friction. ${BRAND} is that.`],
      ["How it works under the hood", "The frontend is a static, pre-rendered site hosted on a CDN for instant load. The backend runs yt-dlp to resolve the best available YouTube streams, then FFmpeg to package them as MP3 (libmp3lame CBR), M4A (AAC re-mux), WAV (PCM), or MP4 (H.264 + AAC). Jobs are processed asynchronously so the UI stays responsive."],
      ["Responsible use", `${BRAND} is intended for downloading content that you have the right to save — your own uploads, Creative Commons material, public-domain works, or content you've licensed. Please respect the terms of the platforms you use and the copyright of the creators whose work you enjoy.`],
    ], faqs: [] },
  { slug: "contact", title: `Contact ${BRAND}`, h1: "Contact",
    kicker: "Questions, feedback, bug reports, or business inquiries — pick the right channel below and we'll read every message.",
    defaultFormat: "mp3", defaultQuality: "320",
    keywords: "ytmp3 contact, contact support, youtube converter support",
    sections: [
      ["General support & bug reports", `Email support@${BRAND.replace("yt2mp3.lol", "yt2mp3.lol")} with a description of the issue, the URL you were converting, the format and quality you picked, and the browser / device you used. Screenshots help. We triage every inbound message within 48 hours.`],
      ["Copyright takedown requests", "If you own the rights to content you believe has been converted in violation of your copyright, please see the Copyright Claims page for the DMCA-style notice format we require. Misdirected takedown emails may be delayed — the dedicated form routes to our legal inbox immediately."],
      ["Business & partnerships", "For ad-free sponsorship, API licensing, or white-label inquiries, email partnerships at our domain with a short pitch and your contact details."],
    ],
    faqs: [
      ["Why haven't I received a reply?", "Check your spam folder. Our auto-reply sometimes lands there. If you're still not seeing anything after 72 hours, re-send from a different address."],
      ["Do you have a phone number?", "We operate asynchronously over email to keep operating costs low, which is what lets the service stay free."],
    ] },
  { slug: "copyright-claims", title: "Copyright Claims & DMCA Notices", h1: "Copyright Claims",
    kicker: "If you believe content available through our service infringes your copyright, submit a notice using the format below and we will respond promptly.",
    defaultFormat: "mp3", defaultQuality: "320",
    keywords: "ytmp3 copyright, dmca notice, copyright claim, takedown request",
    sections: [
      ["Our approach", `${BRAND} hosts no content of its own. Files are generated on demand from URLs users supply and are deleted shortly after download. That said, we take copyright seriously and act on valid notices quickly.`],
      ["What to include in a notice", "A complete notice needs: (1) your contact information (name, address, email, phone); (2) identification of the copyrighted work you claim was infringed; (3) the specific URL(s) that were used with our converter and that you want us to block; (4) a good-faith statement that the use is not authorized; (5) a statement, under penalty of perjury, that the information is accurate and you are the rights holder or authorized to act on their behalf; (6) your physical or electronic signature."],
      ["Where to send it", `Email the notice to dmca at our domain. Incomplete notices will be returned for correction. We reserve the right to share valid notices with the user who submitted the URL, in accordance with the counter-notification process below.`],
      ["Counter-notifications", "Users whose URLs have been blocked may submit a counter-notification using the same structure, asserting under penalty of perjury that the material was blocked by mistake or misidentification. If no court action is filed within 10 business days, access is restored."],
      ["Repeat infringers", "We reserve the right to permanently block URLs, IP addresses, or accounts associated with repeat infringement."],
    ], faqs: [] },
  { slug: "privacy-policy", title: "Privacy Policy", h1: "Privacy Policy",
    kicker: `How ${BRAND} collects, uses, and protects information. Plain language, no dark patterns.`,
    defaultFormat: "mp3", defaultQuality: "320",
    keywords: "ytmp3 privacy policy, youtube converter privacy",
    sections: [
      ["What we collect", "Minimal technical data: IP address (for abuse prevention and rate limiting), user-agent string (browser and OS), and the URLs you submit for conversion (only while a job is in progress). We do not set identification cookies, do not use fingerprinting, and do not share data with advertising networks."],
      ["What we do not collect", "No name, no email unless you contact support, no location beyond the rough inference from IP, no browsing history, no information about other tabs or apps on your device."],
      ["Conversion files", "Converted files are stored on our servers only long enough for you to download them (default 30 minutes) and are then permanently deleted. We do not scan, catalog, or back up the content."],
      ["Analytics", "We use privacy-respecting server-side logging to count requests per endpoint and troubleshoot errors. No per-user analytics or session recording."],
      ["Third parties", "The only third-party services our backend contacts are YouTube itself (to fetch the source video) and our hosting provider's infrastructure. We do not integrate ad networks, trackers, or social widgets."],
      ["Your rights", "You can request deletion of any information we hold about you by emailing privacy at our domain. We will respond within 30 days. If you are in the EU, you have additional rights under GDPR; if you are in California, you have additional rights under the CCPA — we honor both."],
      ["Changes", "Material changes to this policy will be announced at the top of this page for at least 30 days before taking effect."],
    ], faqs: [] },
  { slug: "terms-of-use", title: "Terms of Use", h1: "Terms of Use",
    kicker: `By using ${BRAND} you agree to the terms below. Read them carefully — they are binding.`,
    defaultFormat: "mp3", defaultQuality: "320",
    keywords: "ytmp3 terms, terms of use, service agreement",
    sections: [
      ["1. The service", `${BRAND} provides a web-based media conversion utility. You paste a URL; we fetch the media from the source platform and re-encode it into the format you requested. The service is provided free of charge on an "as is" basis.`],
      ["2. Acceptable use", "You agree to use the service only for lawful purposes. In particular, you represent that for any URL you submit, you have the right to download and save the underlying content — because it is your own upload, because it is under a permissive license (Creative Commons, public domain), because you have the rights holder's authorization, or because your jurisdiction's law allows personal-use private copying. Using the service to reproduce copyrighted works without authorization is prohibited."],
      ["3. Prohibited activities", "You may not: (a) use the service to stalk, harass, or defame anyone; (b) attempt to break, overwhelm, or reverse-engineer the infrastructure; (c) scrape or resell the converted files; (d) use automation to generate more than 50 requests per minute from a single IP."],
      ["4. No warranty", "The service is provided without warranty of any kind, express or implied. We do not guarantee uptime, conversion quality, or compatibility with any specific device or file format. YouTube may change its infrastructure at any time, which can temporarily or permanently break the service."],
      ["5. Limitation of liability", "To the maximum extent permitted by law, we are not liable for any indirect, incidental, consequential, special, or exemplary damages arising from your use of the service. Our total liability for any claim is capped at the amount you have paid us in the last 12 months, which for free users is zero."],
      ["6. Termination", "We may suspend or terminate your access at any time for violations of these terms, for abuse of the service, or at our discretion to protect the service."],
      ["7. Governing law", "These terms are governed by the laws of the operator's jurisdiction. Disputes will be resolved by binding arbitration or in a court of competent jurisdiction, at our election."],
      ["8. Changes", "We may update these terms. Material changes will be posted at the top of this page at least 30 days before taking effect. Continued use after the effective date constitutes acceptance."],
    ], faqs: [] }
];

// Dynamically expand landing pages to 10+ H2 sections and 10-12 FAQs
PAGES.forEach(p => {
  if (["faq", "about", "contact", "copyright-claims", "privacy-policy", "terms-of-use", "youtube-multi-downloader"].includes(p.slug)) return;
  
  // Add format tables section
  p.sections.push([
    "Format Comparison Table",
    `<div style="overflow-x:auto;">
      <table style="width:100%; border-collapse: collapse; text-align: left;">
        <tr style="border-bottom: 1px solid var(--border);">
          <th style="padding: 8px;">Format</th>
          <th style="padding: 8px;">Best For</th>
          <th style="padding: 8px;">Quality Options</th>
          <th style="padding: 8px;">File Size</th>
        </tr>
        <tr style="border-bottom: 1px solid var(--border);">
          <td style="padding: 8px;">MP3</td><td style="padding: 8px;">Universal audio playback</td><td style="padding: 8px;">128 - 320 kbps</td><td style="padding: 8px;">Small</td>
        </tr>
        <tr style="border-bottom: 1px solid var(--border);">
          <td style="padding: 8px;">MP4</td><td style="padding: 8px;">Video playback everywhere</td><td style="padding: 8px;">360p - 2160p (4K)</td><td style="padding: 8px;">Large</td>
        </tr>
        <tr style="border-bottom: 1px solid var(--border);">
          <td style="padding: 8px;">WAV</td><td style="padding: 8px;">Lossless audio editing</td><td style="padding: 8px;">16-bit 44.1kHz</td><td style="padding: 8px;">Very Large</td>
        </tr>
        <tr>
          <td style="padding: 8px;">M4A</td><td style="padding: 8px;">Apple devices</td><td style="padding: 8px;">Native AAC</td><td style="padding: 8px;">Medium</td>
        </tr>
      </table>
    </div>`
  ]);


  const contentMap = {"youtube-to-mp4-converter": {"sections": [["High-Definition MP4 Downloads", "Unlike converters that compress your files to save bandwidth, our tool fetches the highest available MP4 quality directly from YouTube's servers. Whether the original upload is in 720p, 1080p, 1440p (QHD), or 2160p (4K), you receive an uncompromised H.264 video file paired with AAC audio for universal compatibility."], ["Why MP4 is the Best Format", "MP4 is the industry standard for digital video. It offers an exceptional balance between file size and video quality. Most importantly, MP4 files play natively on every modern device\u2014from iPhones and Android smartphones to Smart TVs, PlayStation, Xbox, and all major video editing software like Premiere Pro and Final Cut."], ["Bypass Buffering for Offline Viewing", "Internet connections can be unreliable, and YouTube ads can ruin the viewing experience. By converting your favorite documentaries, tutorials, or music videos to MP4, you guarantee uninterrupted, ad-free playback during flights, commutes, or in areas with poor cellular reception."], ["Hardware-Accelerated FFmpeg Processing", "Behind the scenes, we utilize clustered servers running hardware-accelerated FFmpeg. This means that when we mux the separate high-resolution video and audio tracks from YouTube into a single MP4, the process takes seconds rather than minutes. You get your file almost instantly."], ["No Watermarks or Time Limits", "Many free tools slap a huge watermark on your video or limit you to 5-minute clips. We believe in providing a premium experience for free. You can download 3-hour long podcasts or full-length public domain movies in MP4 format with absolutely zero watermarks."], ["Safe, Secure, and Private", "We respect your digital privacy. Our MP4 converter runs entirely in your browser through secure API calls. We don't require you to install sketchy browser extensions, we don't ask for your email address, and we automatically purge your converted files from our cache within 30 minutes."], ["Compatible with All Browsers", "Whether you are a power user on Chrome, a privacy advocate using Brave or Firefox, or browsing on Safari on your iPad, our web-based tool functions flawlessly. No need to worry about OS compatibility or downloading separate desktop apps."], ["Perfect for Content Creators", "If you need B-roll footage, stock videos, or meme templates, our MP4 downloader provides the raw files you need to import directly into your timeline. The standard H.264 codec ensures you won't need to transcode the footage before editing."], ["Format Comparison Table", "<div style=\"overflow-x:auto;\">\n      <table style=\"width:100%; border-collapse: collapse; text-align: left;\">\n        <tr style=\"border-bottom: 1px solid var(--border);\"><th style=\"padding: 8px;\">Format</th><th style=\"padding: 8px;\">Best For</th><th style=\"padding: 8px;\">Resolution Range</th><th style=\"padding: 8px;\">File Size</th></tr>\n        <tr style=\"border-bottom: 1px solid var(--border);\"><td style=\"padding: 8px;\">MP4</td><td style=\"padding: 8px;\">Universal Video Playback</td><td style=\"padding: 8px;\">360p - 2160p (4K)</td><td style=\"padding: 8px;\">Large</td></tr>\n        <tr style=\"border-bottom: 1px solid var(--border);\"><td style=\"padding: 8px;\">WEBM</td><td style=\"padding: 8px;\">Web Browsers</td><td style=\"padding: 8px;\">Up to 4K</td><td style=\"padding: 8px;\">Medium</td></tr>\n        <tr style=\"border-bottom: 1px solid var(--border);\"><td style=\"padding: 8px;\">MP3</td><td style=\"padding: 8px;\">Audio Only</td><td style=\"padding: 8px;\">Up to 320 kbps</td><td style=\"padding: 8px;\">Small</td></tr>\n      </table>\n    </div>"], ["Step-by-Step Conversion Process", "1. Copy the YouTube URL. 2. Paste it into the search box. 3. Select 'MP4' and choose your desired resolution (e.g., 1080p). 4. Click 'Convert'. Our servers will instantly begin fetching and muxing the streams. 5. Click the download link to save the MP4 directly to your device's local storage."]], "faqs": [["Is downloading MP4s from YouTube legal?", "You should only download content that you own, have permission to use, or that is licensed under Creative Commons or is in the public domain. Please respect copyright laws in your jurisdiction."], ["Why isn't 4K available for all videos?", "Our tool can only provide resolutions that were originally uploaded by the creator. If a video was filmed and uploaded in 1080p, a 4K option will not exist."], ["Does the downloaded MP4 have sound?", "Yes! While YouTube stores high-res video and audio separately, our FFmpeg backend automatically merges (muxes) the video and audio tracks so you get a complete, playable MP4 file."], ["How long does the conversion take?", "For standard 1080p videos under 10 minutes, conversion usually takes 5-15 seconds. Longer videos (e.g., 2 hours) or 4K files will take proportionally longer due to file size."], ["Can I download MP4s on my iPhone?", "Yes. You can use Safari on iOS to access our site. Once converted, tap 'Download' and Safari will save the MP4 directly into your Files app or Photos app."], ["Is there a limit on file size or length?", "We currently support videos up to 3 hours in length to ensure our servers remain fast and stable for all users. There are no daily usage limits."], ["Do I need to install any software?", "No. Everything is handled cloud-side. You do not need to install any desktop software, mobile apps, or browser extensions."], ["Why did my download fail midway?", "This usually happens due to a network interruption on your end, or if the video is suddenly made private or age-restricted. Simply refresh the page and try again."], ["Are there any viruses or malware?", "Our service is 100% clean. We do not inject ads into the video, and we do not use deceptive download buttons. You receive the pure video file."], ["Can I convert a playlist to MP4?", "Yes, we support playlist conversions. Simply paste the playlist URL, and you can queue up all the videos to be downloaded as separate MP4 files."]]}, "youtube-shorts-downloader": {"sections": [["Download Shorts in Original 9:16 Format", "YouTube Shorts are designed for vertical screens. Our converter detects Shorts URLs and ensures that the downloaded MP4 preserves the original 9:16 portrait aspect ratio. You get the exact video as it appears on your phone, without any ugly black bars or artificial cropping."], ["Extract Viral Audio with MP3", "Often, the best part of a YouTube Short is the trending audio, meme sound, or background track. By selecting the MP3 option, you can rip just the audio track at a crisp 320kbps. This is perfect for creating your own ringtones, soundboards, or using the audio in your own TikToks and Reels."], ["No App Installation Necessary", "Don't clutter your phone with shady downloader apps from the app store. Our YouTube Shorts Downloader works flawlessly via your mobile browser (Chrome, Safari, Firefox). Just use the 'Share' > 'Copy Link' feature in the YouTube app and paste it here."], ["Ultra-Fast Processing for Short Clips", "Because Shorts are under 60 seconds by definition, our backend processes them almost instantaneously. In most cases, your download link will be ready in under 3 seconds, allowing you to quickly save multiple Shorts in a row."], ["Bypass Content Restrictions", "Sometimes creators delete their viral Shorts, or the platform mutes the audio due to copyright disputes. By downloading the Short directly to your device, you secure a permanent offline copy that can never be altered or removed from your library."], ["Perfect for Cross-Posting", "Are you a social media manager or creator looking to cross-post your content? Download your own YouTube Shorts in pristine 1080p MP4 format and natively upload them to TikTok, Instagram Reels, or Snapchat Spotlight without watermarks."], ["Batch Download Shorts from Playlists", "If you've saved a bunch of funny Shorts to a public playlist, you don't have to download them one by one. Paste the playlist URL into our tool, and it will generate individual download links for every Short in the collection."], ["Seamless iOS and Android Integration", "On iPhones, Safari will download the Short directly to your 'Files' app, from which you can easily save it to your Camera Roll. On Android, Chrome saves it straight to your 'Downloads' folder or Gallery for immediate viewing."], ["Format Comparison Table", "<div style=\"overflow-x:auto;\">\n      <table style=\"width:100%; border-collapse: collapse; text-align: left;\">\n        <tr style=\"border-bottom: 1px solid var(--border);\"><th style=\"padding: 8px;\">Format</th><th style=\"padding: 8px;\">Best For</th><th style=\"padding: 8px;\">Aspect Ratio</th><th style=\"padding: 8px;\">Quality</th></tr>\n        <tr style=\"border-bottom: 1px solid var(--border);\"><td style=\"padding: 8px;\">MP4</td><td style=\"padding: 8px;\">Video playback, reposting</td><td style=\"padding: 8px;\">9:16 (Vertical)</td><td style=\"padding: 8px;\">Up to 1080p</td></tr>\n        <tr style=\"border-bottom: 1px solid var(--border);\"><td style=\"padding: 8px;\">MP3</td><td style=\"padding: 8px;\">Audio extraction, ringtones</td><td style=\"padding: 8px;\">N/A</td><td style=\"padding: 8px;\">320 kbps</td></tr>\n      </table>\n    </div>"], ["How to Download YouTube Shorts", "1. Open the YouTube app and watch a Short. 2. Tap the 'Share' arrow and select 'Copy Link'. 3. Open your mobile browser and navigate to our site. 4. Paste the link into the input field. 5. Choose MP4 for video or MP3 for audio, then tap 'Convert'. 6. Tap 'Download' to save the file."]], "faqs": [["What is the difference between a Short and a regular video?", "Technically, very little. Shorts are just vertical videos (9:16 ratio) that are 60 seconds or less. Our system handles them using the same high-speed extraction engine as regular videos."], ["Will the downloaded Short have a YouTube watermark?", "No. Unlike some other platforms, YouTube does not embed a hardcoded watermark into the video file itself. Your downloaded MP4 will be clean and watermark-free."], ["Can I download Shorts in 4K?", "Most Shorts are uploaded at a maximum resolution of 1080p to optimize for mobile screens. If a creator managed to upload a 4K vertical video, our tool will capture it, but 1080p is the standard maximum."], ["How do I save the Short to my iPhone Camera Roll?", "After downloading the MP4 via Safari, open the 'Files' app, locate the video in your Downloads folder, tap the share icon, and select 'Save Video'."], ["Why did the MP3 extraction fail?", "This is extremely rare, but if a Short has been completely muted by YouTube due to copyright claims, there is no audio track for our servers to extract."], ["Is there a limit to how many Shorts I can download?", "No! You can download as many Shorts as you like. Our service is completely unlimited and free of charge."], ["Can I download unlisted Shorts?", "Yes, as long as you have the direct link to the unlisted Short, our tool can access and convert it. We cannot access Private Shorts."], ["Does the tool work on desktop computers?", "Absolutely. You can copy the URL of a Short from your desktop browser (e.g., youtube.com/shorts/...) and paste it into our tool just like any other link."], ["What happens to the video thumbnail?", "For MP3 downloads, we embed the Short's thumbnail as the album artwork. For MP4 downloads, the video file itself contains the first frame as the poster image."], ["Are the downloads safe from viruses?", "Yes, the files are generated directly from YouTube's servers via FFmpeg muxing. We do not alter the files or inject malicious code."]]}, "youtube-playlist-downloader": {"sections": [["Batch Conversion Masterclass", "Downloading videos one by one is incredibly tedious. Our YouTube Playlist Downloader is engineered for bulk operations. By parsing the playlist metadata, our servers generate individual conversion jobs for every single video in the list, allowing you to download an entire album, lecture series, or podcast backlog with minimal effort."], ["Preserve Original Order and Titles", "When you download a playlist, organization is key. Our system automatically grabs the original video titles and structures the downloads so you can easily maintain the intended order. This is perfect for sequential tutorials, multi-part documentaries, or chronologically ordered music albums."], ["Flexible Format Selection for Playlists", "You aren't locked into a single format. You can choose to download an entire music playlist as crisp 320kbps MP3s, or an entire educational course as 1080p MP4s. Our FFmpeg backend applies your selected format uniformly across all items in the batch."], ["High-Concurrency Processing", "We don't make you wait for one video to finish before starting the next. Our cloud infrastructure utilizes high-concurrency processing, meaning multiple videos from your playlist are downloaded and converted simultaneously. A 50-video playlist is processed significantly faster than doing it manually."], ["Support for Massive Playlists", "Whether it's a 10-track EP or a massive 300-video mega-mix, our tool is built to handle it. While extremely large playlists may take a few minutes to fully parse and render download buttons, our backend will not time out or crash during the operation."], ["Download Auto-Generated Mixes", "Did YouTube's algorithm create the perfect 'My Mix' or 'Discover Weekly' equivalent for you? Just copy the URL of that auto-generated playlist and paste it here. You can rip the entire curated mix to your local device for offline listening on road trips or flights."], ["Ideal for Educators and Students", "Many professors and online instructors organize their course modules into public YouTube playlists. Students can use our tool to download the entire semester's worth of lectures in MP4 format, ensuring they have access to study materials even without an internet connection."], ["Handling Unavailable or Private Videos", "Playlists often contain videos that have been deleted, made private, or restricted in your region. Our parser intelligently skips these dead links and continues processing the available videos, so your batch download isn't ruined by a single broken link."], ["Format Comparison Table", "<div style=\"overflow-x:auto;\">\n      <table style=\"width:100%; border-collapse: collapse; text-align: left;\">\n        <tr style=\"border-bottom: 1px solid var(--border);\"><th style=\"padding: 8px;\">Format</th><th style=\"padding: 8px;\">Best Use Case for Playlists</th><th style=\"padding: 8px;\">Storage Impact</th></tr>\n        <tr style=\"border-bottom: 1px solid var(--border);\"><td style=\"padding: 8px;\">MP3 (320kbps)</td><td style=\"padding: 8px;\">Music albums, Spotify alternatives</td><td style=\"padding: 8px;\">Low (~10MB/track)</td></tr>\n        <tr style=\"border-bottom: 1px solid var(--border);\"><td style=\"padding: 8px;\">M4A (AAC)</td><td style=\"padding: 8px;\">Podcasts, Audiobooks on Apple devices</td><td style=\"padding: 8px;\">Very Low</td></tr>\n        <tr style=\"border-bottom: 1px solid var(--border);\"><td style=\"padding: 8px;\">MP4 (720p/1080p)</td><td style=\"padding: 8px;\">Lecture series, TV show episodes</td><td style=\"padding: 8px;\">High (~500MB/video)</td></tr>\n      </table>\n    </div>"], ["How to Download a Full Playlist", "1. Navigate to the playlist on YouTube. Ensure the URL contains 'list=' (e.g., youtube.com/playlist?list=...). 2. Copy the URL. 3. Paste it into our converter. 4. Select your global format (MP3 or MP4). 5. Click Convert. 6. Wait for the parser to extract the videos, then click the individual download buttons as they appear."]], "faqs": [["Is there a limit to the number of videos in a playlist?", "We can theoretically parse playlists of any size, but for optimal performance and browser stability, we recommend downloading playlists with 200 videos or fewer at a time."], ["Will it download as one giant file or separate files?", "Each video in the playlist is converted and downloaded as its own separate file. We do not merge them into a single massive audio/video file."], ["Can I download a 'Watch Later' playlist?", "Your 'Watch Later' playlist is private to your account. Our servers cannot access it. You would need to move those videos to a Public or Unlisted playlist first."], ["What happens if the playlist contains a live stream?", "If the live stream has ended and is available as a VOD, it will download normally. If the stream is currently live, the tool will skip it, as it has no finite length."], ["How long does a 50-video playlist take to convert?", "Parsing the list takes only seconds. The conversion time depends on the total length of the videos and the chosen quality, but our concurrent processing usually finishes a typical music playlist in under 3 minutes."], ["Do I have to click download 50 times?", "Currently, browser security restrictions prevent websites from automatically triggering 50 file downloads at once. You will need to click the download button for each generated file."], ["Does it download the playlist thumbnail?", "The individual video files will have their respective video thumbnails embedded as metadata (for audio formats) or as the poster frame (for video formats)."], ["Can I download a channel's entire video list?", "If the channel has a 'Play All' button or a playlist containing all their uploads, yes. Just copy that specific playlist URL."], ["Are the files numbered?", "The files retain their original YouTube titles. If the creator numbered the titles (e.g., 'Episode 1: ...'), that numbering will be in your downloaded file."], ["Why did only half the videos appear?", "This usually means the missing videos are either Private, Deleted, or Region-Blocked. Our tool can only fetch publicly accessible media."]]}, "youtube-multi-downloader": {"sections": [["The Ultimate Tool for Researchers and DJs", "When you need to grab dozens of specific clips from various channels, creating a custom playlist is too slow. Our Multiple YouTube Downloader allows you to paste a massive list of disparate YouTube URLs\u2014separated by commas or newlines\u2014and process them all simultaneously. It is the ultimate workflow hack for DJs building sample libraries or researchers archiving footage."], ["Parallel Processing Engine", "Our backend doesn't queue your URLs sequentially. We utilize a highly parallelized processing engine. If you paste 15 URLs, our cloud nodes spin up 15 simultaneous yt-dlp/FFmpeg instances. This concurrent approach slashes your waiting time by up to 90% compared to traditional, single-threaded converter sites."], ["Mix and Match URL Types", "The multi-downloader is highly robust. You can mix standard video URLs, YouTube Shorts URLs, and even individual music track URLs in the same batch. The parser intelligently identifies each link type and routes it through the appropriate extraction pipeline."], ["Resilient Error Handling", "In a batch of 50 URLs, one or two might be dead links, private videos, or age-restricted. Instead of failing the entire batch, our resilient error handling simply flags the problematic links with a clear error message while successfully completing the rest of the downloads."], ["Bulk Audio Extraction (MP3/WAV)", "DJs and music producers love the multi-downloader for bulk audio extraction. Paste a list of rare tracks or sound effects, select WAV for lossless extraction or 320kbps MP3 for library management, and watch as our tool rapidly rips the audio tracks for your next set."], ["Streamlined UI for Power Users", "We designed the interface specifically for power users. The massive text area accommodates hundreds of links, and the progress tracking UI dynamically updates to show the real-time status (Queued, Downloading, Processing, Ready) of every individual job in your batch."], ["No Rate Limiting", "We understand that bulk downloading requires high throughput. We have engineered our API and configured residential proxies to bypass YouTube's aggressive rate-limiting, ensuring that your large batches complete successfully without triggering CAPTCHAs or IP blocks."], ["Perfect for Offline Archiving", "If you are curating an offline archive of important news clips, tutorials, or historical footage, the multi-downloader allows you to rapidly secure local copies before the content is potentially taken down by the platform."], ["Format Comparison Table", "<div style=\"overflow-x:auto;\">\n      <table style=\"width:100%; border-collapse: collapse; text-align: left;\">\n        <tr style=\"border-bottom: 1px solid var(--border);\"><th style=\"padding: 8px;\">Format</th><th style=\"padding: 8px;\">Batch Processing Speed</th><th style=\"padding: 8px;\">Best For</th></tr>\n        <tr style=\"border-bottom: 1px solid var(--border);\"><td style=\"padding: 8px;\">MP3 (128kbps)</td><td style=\"padding: 8px;\">Lightning Fast</td><td style=\"padding: 8px;\">Speech, podcasts, quick archives</td></tr>\n        <tr style=\"border-bottom: 1px solid var(--border);\"><td style=\"padding: 8px;\">MP3 (320kbps)</td><td style=\"padding: 8px;\">Very Fast</td><td style=\"padding: 8px;\">Music libraries, DJ sets</td></tr>\n        <tr style=\"border-bottom: 1px solid var(--border);\"><td style=\"padding: 8px;\">MP4 (1080p)</td><td style=\"padding: 8px;\">Moderate</td><td style=\"padding: 8px;\">High-quality video archiving</td></tr>\n      </table>\n    </div>"], ["How to Use the Multi-Downloader", "1. Gather your YouTube URLs. 2. Paste them into the large text area, ensuring each URL is on a new line. 3. Select the desired global format (e.g., MP3 or MP4) for the batch. 4. Click 'Convert All'. 5. Scroll down to monitor the progress of each individual file. 6. Click 'Download' on each completed item."]], "faqs": [["How many URLs can I paste at once?", "We recommend a soft limit of 50 URLs per batch to ensure your browser doesn't become overwhelmed rendering the UI. If you have more, simply do them in chunks of 50."], ["Do I need to separate the URLs in a specific way?", "Yes, please place each URL on a new line (press Enter after pasting each link). This ensures the parser reads them correctly."], ["Can I choose a different format for each URL in the batch?", "Currently, the selected format (e.g., MP3 320kbps) applies globally to all URLs in that specific batch submission. You would need to run separate batches for different formats."], ["What happens if I accidentally include a non-YouTube link?", "Our validation script will automatically detect and ignore URLs that do not match standard YouTube, youtu.be, or Shorts domains. The valid links will still process."], ["Is the multi-download feature free?", "Yes, absolutely. We do not put our batch processing tools behind a paywall. It is 100% free for all users."], ["Will this slow down my internet connection?", "The conversion process happens on our servers, so it won't affect your CPU or internet speed. However, downloading 50 files simultaneously to your local machine will utilize your available bandwidth."], ["Can I pause and resume a batch?", "No, once a batch is submitted to our servers, the backend jobs run to completion. You cannot pause the remote processing."], ["Do you offer a ZIP download for the whole batch?", "To minimize server load and deliver files to you faster, we provide individual download links as soon as each file finishes, rather than waiting for the entire batch to zip."], ["Why do some videos finish faster than others?", "Shorter videos and lower quality settings require less processing time. An audio-only extraction of a 3-minute song will finish long before a 1080p MP4 conversion of a 20-minute vlog."], ["Is this safe for mobile devices?", "Yes, but be aware that downloading dozens of files simultaneously on a mobile browser can be tricky to manage. We recommend using the multi-downloader on a desktop computer for the best experience."]]}, "youtube-to-mp3-320kbps-converter": {"sections": [["True 320kbps Audio Quality", "Not all MP3 converters are created equal. Many shady sites advertise '320kbps' but actually just take a low-quality 128kbps stream and pad it with empty data to fake a higher bitrate. We use FFmpeg's libmp3lame encoder to rip the highest quality Opus or AAC stream from YouTube and intelligently re-encode it at a true, constant bitrate (CBR) of 320kbps. The difference in audio fidelity is noticeable on good headphones."], ["The Audiophile's Choice for MP3", "While lossless formats like WAV are superior, 320kbps is widely considered the transparent threshold for the MP3 codec. This means that to the human ear, a 320kbps MP3 is virtually indistinguishable from the original uncompressed source. It is the perfect balance, providing studio-like sound while keeping file sizes manageable for smartphones and USB drives."], ["Preserving the Low End and High Frequencies", "Lower bitrate MP3s (like 128kbps) aggressively cut off high frequencies (often introducing a 'swishy' or 'underwater' sound to cymbals) and muddy the bass to save space. Our 320kbps engine preserves the full frequency spectrum (up to 20kHz), ensuring your downloaded music retains its original punch, clarity, and spatial imaging."], ["Seamless DJ and Mixing Integration", "If you use software like Serato, Rekordbox, or Traktor, audio quality is paramount. Playing a fake/upscaled 128kbps track on a club PA system sounds terrible. By guaranteeing a proper 320kbps encode, our files will pass the spectrum analyzer test and sound pristine when played loud on professional sound systems."], ["Automatic Metadata and ID3 Tags", "We don't just give you raw audio data. Our backend automatically extracts the video title and embeds it into the MP3's ID3 tags. Furthermore, we grab the highest resolution video thumbnail and embed it as the album cover art. When you load the MP3 into Apple Music, Spotify Local Files, or your car's media player, it looks polished and professional."], ["Lightning Fast Extraction", "Because we are extracting audio rather than rendering complex video frames, the conversion process is incredibly fast. Even a 1-hour DJ mix can be extracted, encoded to 320kbps, tagged, and ready for download in under 20 seconds. It is the fastest way to build your offline music library."], ["Bypass YouTube Music Premium", "Why pay a monthly subscription just to listen to music offline? With our converter, you can curate your own localized library of high-quality MP3s for free. Transfer them to your phone, smartwatch, or MP3 player and enjoy your music anywhere without cellular data or subscription fees."], ["Compatible with Everything", "The MP3 format is universally supported. Unlike newer formats like Opus or ALAC, which might require specific apps, a 320kbps MP3 will play flawlessly on legacy car stereos, classic iPods, modern smartphones, and every media player application in existence."], ["Format Comparison Table", "<div style=\"overflow-x:auto;\">\n      <table style=\"width:100%; border-collapse: collapse; text-align: left;\">\n        <tr style=\"border-bottom: 1px solid var(--border);\"><th style=\"padding: 8px;\">Audio Format</th><th style=\"padding: 8px;\">Bitrate / Specs</th><th style=\"padding: 8px;\">Audio Quality</th><th style=\"padding: 8px;\">File Size (per min)</th></tr>\n        <tr style=\"border-bottom: 1px solid var(--border);\"><td style=\"padding: 8px;\">MP3 (Low)</td><td style=\"padding: 8px;\">128 kbps CBR</td><td style=\"padding: 8px;\">Acceptable (Good for speech)</td><td style=\"padding: 8px;\">~1.0 MB</td></tr>\n        <tr style=\"border-bottom: 1px solid var(--border);\"><td style=\"padding: 8px;\">MP3 (High)</td><td style=\"padding: 8px;\">320 kbps CBR</td><td style=\"padding: 8px;\">Excellent (Transparent)</td><td style=\"padding: 8px;\">~2.4 MB</td></tr>\n        <tr style=\"border-bottom: 1px solid var(--border);\"><td style=\"padding: 8px;\">WAV</td><td style=\"padding: 8px;\">16-bit / 44.1kHz PCM</td><td style=\"padding: 8px;\">Lossless (Studio)</td><td style=\"padding: 8px;\">~10.0 MB</td></tr>\n      </table>\n    </div>"], ["How to Download 320kbps MP3s", "1. Copy the URL of your desired YouTube video or music track. 2. Paste the link into the converter box. 3. Ensure the format is set to 'MP3' and select '320kbps' from the quality dropdown. 4. Hit the Convert button. 5. Once the FFmpeg processing is complete, click the download link to save your high-fidelity track."]], "faqs": [["Does YouTube actually stream in 320kbps?", "YouTube typically streams audio using the Opus codec at around 128-160kbps, or AAC at 128kbps (which is highly efficient and sounds great). Our 320kbps MP3 encode ensures that we capture this source audio without introducing any further compression artifacts during the format conversion."], ["Can I convert a 10-hour sleep sounds video?", "We currently cap conversions at 3 hours to prevent server timeouts and manage disk space. 10-hour videos are not supported at this time."], ["Why is the file size larger than a normal MP3?", "A true 320kbps MP3 consumes about 2.4 Megabytes per minute of audio. It is larger than a 128kbps file because it contains significantly more audio data, preserving the high and low frequencies."], ["Will this work on my Mac?", "Yes. MP3s downloaded from our site can be dragged directly into the Apple Music (formerly iTunes) app on your Mac, and they will sync seamlessly to your iPhone or iPad."], ["Does it include the album artwork?", "Yes! We automatically pull the YouTube video thumbnail and embed it directly into the MP3 file as ID3 album art data."], ["Is there any loss of quality?", "Because we are converting from YouTube's lossy format to MP3 (another lossy format), there is technically a generational transcode. However, by using the maximum 320kbps bitrate and the high-quality LAME encoder, this loss is mathematically negligible and imperceptible to the human ear."], ["Can I use this for podcasts?", "Absolutely. However, if space is a concern, you might want to choose a lower bitrate like 128kbps for speech-heavy podcasts, as 320kbps is generally overkill for spoken word."], ["Do I have to pay for 320kbps?", "No. Many other sites lock 320kbps behind a 'Pro' or 'Premium' paywall. We provide our highest quality encoding to all users for free."], ["Can I convert YouTube Music links?", "Yes. If you have a link from music.youtube.com, our backend will properly resolve it and extract the audio just like a standard YouTube video link."], ["What if the video has no audio?", "If a video literally contains no audio track (e.g., a silent CCTV clip), the conversion will fail, and our system will alert you that no audio stream was found."]]}, "wav-converter": {"sections": [["Uncompromised Lossless WAV Extraction", "For audio professionals, producers, and audiophiles, MP3 compression is unacceptable. MP3 is a 'lossy' format that permanently deletes acoustic data to save space. Our WAV converter bypasses lossy compression entirely. We extract the raw audio stream from YouTube and decode it into an uncompressed, lossless 16-bit 44.1kHz PCM WAV file\u2014the exact same standard used for CD audio."], ["The Ultimate Source for Sampling", "If you are producing music in Ableton, FL Studio, or Logic Pro, you need pristine audio. When you chop samples, time-stretch, or pitch-shift audio, compression artifacts in MP3s become blatantly obvious and ruin your mix. By starting with our uncompressed WAV files, your DAW has clean, raw waveform data to manipulate, ensuring your beats and edits sound professional."], ["Archival Quality Preservation", "Are you preserving historical speeches, rare interviews, or old public domain music found only on YouTube? Archiving in a lossy format like MP3 introduces generational degradation. WAV is an archival-grade container. By converting to WAV, you ensure that the audio is captured with 100% of the fidelity provided by the YouTube source, protected against future compression loss."], ["Zero Re-Encoding Artifacts", "When standard converters change YouTube's AAC/Opus audio into MP3, they run it through a lossy encoder. This 'transcoding' stacks compression artifacts on top of compression artifacts. Our WAV extraction process merely decodes the source to PCM. There is no second layer of lossy encoding. You get exactly what YouTube broadcasted, mathematically translated to a raw waveform."], ["Perfect for Sound Design and Foley", "Sound designers often scour YouTube for obscure sound effects\u2014from engine revs to ambient room tones. For foley work, audio clarity is non-negotiable. Our WAV converter delivers the uncompressed audio required to apply heavy EQ, reverb, and spatial processing without amplifying the digital 'swish' or 'mud' inherent in low-bitrate MP3s."], ["Universally Compatible Uncompressed Audio", "WAV (Waveform Audio File Format) is an incredibly mature and robust format developed by Microsoft and IBM. It is universally recognized by every operating system, media player, and piece of audio editing software in existence. You will never encounter a 'codec not supported' error when using a WAV file."], ["Instantaneous Decoding Pipeline", "Because we are not mathematically compressing the audio (which requires CPU-intensive algorithms like LAME), decoding to WAV is incredibly fast on our backend. The only bottleneck is the larger file size during the final download to your device. The conversion itself happens in the blink of an eye."], ["Ideal for Video Editors", "If you are editing a video in Premiere Pro or DaVinci Resolve, layering MP3s can sometimes cause sync drift or decoding glitches on the timeline. WAV files are uncompressed and un-packetized, meaning video editors can read them with zero CPU overhead, resulting in smoother timeline playback and perfect audio sync."], ["Format Comparison Table", "<div style=\"overflow-x:auto;\">\n      <table style=\"width:100%; border-collapse: collapse; text-align: left;\">\n        <tr style=\"border-bottom: 1px solid var(--border);\"><th style=\"padding: 8px;\">Feature</th><th style=\"padding: 8px;\">WAV (Our Converter)</th><th style=\"padding: 8px;\">MP3 (Standard)</th></tr>\n        <tr style=\"border-bottom: 1px solid var(--border);\"><td style=\"padding: 8px;\">Compression</td><td style=\"padding: 8px;\">None (Lossless / PCM)</td><td style=\"padding: 8px;\">High (Lossy)</td></tr>\n        <tr style=\"border-bottom: 1px solid var(--border);\"><td style=\"padding: 8px;\">Audio Fidelity</td><td style=\"padding: 8px;\">Exact copy of decoded source</td><td style=\"padding: 8px;\">Frequencies truncated</td></tr>\n        <tr style=\"border-bottom: 1px solid var(--border);\"><td style=\"padding: 8px;\">File Size</td><td style=\"padding: 8px;\">Massive (~10.5 MB / min)</td><td style=\"padding: 8px;\">Small (~2.4 MB / min)</td></tr>\n        <tr style=\"border-bottom: 1px solid var(--border);\"><td style=\"padding: 8px;\">Best Use Case</td><td style=\"padding: 8px;\">DAW Editing, Mastering, Archiving</td><td style=\"padding: 8px;\">Casual Listening, Mobile</td></tr>\n      </table>\n    </div>"], ["How to Convert YouTube to WAV", "1. Copy the YouTube URL containing the audio you need. 2. Paste the link into the converter input field. 3. Select 'WAV' from the format options (Note: quality settings are ignored for WAV, as it is always uncompressed 16-bit PCM). 4. Click Convert. 5. Download the large .wav file directly to your hard drive."]], "faqs": [["Does WAV improve the original audio quality?", "No. It is impossible to 'enhance' or add audio data that doesn't exist. Our WAV converter perfectly captures the YouTube stream without adding further compression. It preserves the exact quality of the source, nothing more, nothing less."], ["Why is the WAV file so huge?", "WAV files are completely uncompressed. Every single audio sample (44,100 times per second per channel) is explicitly stored. This results in file sizes of roughly 10 Megabytes for every minute of audio. A 5-minute song will be ~50MB."], ["Can I play WAV files on my iPhone?", "Yes, iOS natively supports WAV files via the Files app, Safari, and Apple Music. However, due to their massive size, they will fill up your iPhone's storage very quickly compared to MP3 or M4A."], ["Do WAV files support album art?", "Technically, the WAV specification (RIFF) does not formally support ID3 tags like album art, though some modern software hacks it in. To ensure maximum compatibility with DAWs, our WAV files do not contain embedded images."], ["What sample rate and bit depth do you output?", "We output industry-standard 'Red Book' CD quality: 16-bit depth at a 44.1kHz sample rate, stereo. This is the optimal configuration for maximum compatibility across all audio software."], ["Is WAV better than FLAC?", "FLAC is 'lossless compressed' (like a ZIP file for audio), whereas WAV is 'lossless uncompressed'. Both sound identical. We provide WAV because it has 100% universal compatibility with video editors and DAWs without needing special decoders."], ["Can I convert a 2-hour podcast to WAV?", "While possible, we don't recommend it. A 2-hour WAV file will be over 1.2 Gigabytes in size. For long-form speech, MP3 or M4A is a much wiser choice."], ["Why did my DAW reject the WAV file?", "Our WAV files are strictly standard PCM. If your DAW rejects it, ensure you aren't trying to import it into a track with a mismatched sample rate (e.g., trying to force 44.1kHz into a locked 48kHz session without resampling)."], ["Is the WAV extraction free?", "Yes. Uncompressed audio extraction requires more bandwidth on our end due to the large file sizes being downloaded to your device, but we provide this premium feature entirely for free."], ["Can I use this audio commercially?", "Our tool only changes the format of the file; it does not grant you copyright clearance. You must ensure the original YouTube video is royalty-free, public domain, or that you have the creator's permission before using the audio in commercial work."]]}, "m4a-converter": {"sections": [["The Apple Standard: M4A (AAC)", "M4A is an audio container specifically designed by Apple to hold Advanced Audio Coding (AAC) data. It is the exact same high-quality format used by the iTunes Store and Apple Music. If you are deeply integrated into the Apple ecosystem (iPhone, iPad, Mac, HomePod, Apple Watch), converting YouTube videos to M4A is vastly superior to using outdated MP3s."], ["Better Audio Quality at Smaller File Sizes", "AAC is a more modern and highly optimized codec compared to the ancient MP3 standard. At the same bitrate, an M4A (AAC) file sounds demonstrably clearer, with better stereo separation and less high-frequency distortion, than an MP3. Furthermore, it achieves this high fidelity while generating a significantly smaller file size, saving your device's precious storage."], ["Direct Re-Muxing: Zero Quality Loss", "Here is our secret weapon: YouTube natively stores its highest quality audio streams in AAC and Opus formats. When you select our M4A converter, we don't 're-encode' the audio. We perform a 'Direct Stream Copy' (re-muxing), grabbing YouTube's pristine AAC bitstream and wrapping it perfectly inside an M4A container. This means zero generational loss and instantaneous processing."], ["Flawless iOS and macOS Integration", "M4A files are treated as first-class citizens on all Apple devices. They sync effortlessly via iCloud, play natively in QuickTime and Safari without plugins, and import perfectly into Apple Music, GarageBand, and Final Cut Pro. They also support advanced metadata handling, making your library look pristine."], ["Embedded Album Artwork and Metadata", "Unlike some raw formats, the M4A container is fantastic at handling metadata. Our backend automatically extracts the crisp YouTube video thumbnail and embeds it deeply into the M4A file as cover art, alongside the video title and artist metadata. When you play the file on your car's CarPlay display or your iPhone lock screen, it looks like a premium purchased track."], ["Native Support for Android and Windows", "Despite being popularized by Apple, M4A (AAC) is a global ISO standard. It plays perfectly on modern Android devices, Windows Media Player, VLC, and essentially every smartphone built in the last decade. You get the benefits of Apple's preferred format without locking yourself out of other ecosystems."], ["Ideal for Podcasts and Audiobooks", "Because M4A provides incredible clarity at lower bitrates, it is the absolute best format for downloading spoken-word content like 3-hour podcasts, lectures, or audiobooks from YouTube. You get crystal-clear vocals in a file that takes up almost no space on your hard drive."], ["Lower Battery Consumption on Mobile", "Apple devices have dedicated hardware decoding chips specifically for AAC (M4A) files. This means that listening to M4A files on your iPhone drains significantly less battery than listening to MP3s or streaming via Spotify, as the processor doesn't have to work as hard to decode the audio."], ["Format Comparison Table", "<div style=\"overflow-x:auto;\">\n      <table style=\"width:100%; border-collapse: collapse; text-align: left;\">\n        <tr style=\"border-bottom: 1px solid var(--border);\"><th style=\"padding: 8px;\">Feature</th><th style=\"padding: 8px;\">M4A (AAC)</th><th style=\"padding: 8px;\">MP3</th></tr>\n        <tr style=\"border-bottom: 1px solid var(--border);\"><td style=\"padding: 8px;\">Audio Codec Age</td><td style=\"padding: 8px;\">Modern (1997)</td><td style=\"padding: 8px;\">Legacy (1993)</td></tr>\n        <tr style=\"border-bottom: 1px solid var(--border);\"><td style=\"padding: 8px;\">Fidelity at 128kbps</td><td style=\"padding: 8px;\">Excellent (Transparent)</td><td style=\"padding: 8px;\">Noticeable compression</td></tr>\n        <tr style=\"border-bottom: 1px solid var(--border);\"><td style=\"padding: 8px;\">Hardware Decoding</td><td style=\"padding: 8px;\">Native on Apple/Android</td><td style=\"padding: 8px;\">Native everywhere</td></tr>\n        <tr style=\"border-bottom: 1px solid var(--border);\"><td style=\"padding: 8px;\">Re-encoding Required?</td><td style=\"padding: 8px;\">No (Direct copy from YT)</td><td style=\"padding: 8px;\">Yes (Slight quality loss)</td></tr>\n      </table>\n    </div>"], ["How to Download M4A Audio", "1. Copy the YouTube video URL. 2. Paste the link into our converter. 3. Select 'M4A' from the format list. 4. Click Convert. Because this is a direct stream copy, the conversion will finish almost instantly. 5. Download the file and add it to Apple Music or your preferred player."]], "faqs": [["What does M4A stand for?", "M4A stands for MPEG-4 Audio. It is a file extension used to represent audio files encoded with Advanced Audio Coding (AAC) or Apple Lossless Audio Codec (ALAC). Our tool outputs AAC."], ["Is M4A better than MP3?", "Yes. From a technical standpoint, AAC (the codec inside M4A) was designed to be the successor to MP3. It achieves better sound quality at smaller file sizes."], ["Will M4A play on my Android phone?", "Absolutely. Android has natively supported the decoding and playback of M4A (AAC) files since its earliest versions. They work perfectly in Samsung Music, VLC, and Google Files."], ["Why is the conversion so fast compared to MP3?", "When you select MP3, our servers must decode YouTube's audio and re-encode it using LAME, which takes CPU time. When you select M4A, we just copy YouTube's native AAC stream and package it. It's instantaneous."], ["Can I use M4A files in GarageBand?", "Yes, GarageBand, Logic Pro, and iMovie all natively support and heavily prefer M4A files over MP3s. They will import instantly."], ["Does M4A support album art?", "Yes, M4A handles metadata beautifully. We automatically embed the YouTube video thumbnail as the album artwork for the file."], ["Is there any DRM (Digital Rights Management) on these M4A files?", "No. The M4A files generated by our tool are completely DRM-free. You can copy them, share them, and play them on as many devices as you own without authorization restrictions."], ["Can I put these files on an old iPod?", "Yes! Apple iPods (even the classic click-wheel models) were built to play AAC/M4A files natively. They will sync via Finder/iTunes without issue."], ["Are these files Apple Lossless (ALAC)?", "No. Our M4A files use the lossy AAC codec, which is what YouTube streams. ALAC is Apple's lossless format, similar to FLAC or WAV."], ["What is the bitrate of the M4A file?", "It matches exactly what YouTube provides, which is typically a highly-optimized 128kbps AAC stream. Because it's AAC, 128kbps sounds equivalent to or better than a 192kbps MP3."]]}, "iphone-converter": {"sections": [["The Ultimate iPhone YouTube Downloader", "Historically, Apple's strict App Store guidelines have made it incredibly difficult to download YouTube videos directly to your iPhone. Third-party apps get banned, and iTunes syncing requires a desktop computer. Our web-based iPhone Converter solves this completely. It runs entirely within mobile Safari, allowing you to convert and save MP3s and MP4s directly to your iOS device with zero app installations."], ["Direct Integration with the iOS 'Files' App", "Since iOS 13, Safari features a powerful native download manager. When you convert a video on our site and tap download, Safari securely drops the file directly into your iCloud Drive or 'On My iPhone' storage via the native Files app. You have complete control over where the media is stored on your file system."], ["Save Videos to Your Camera Roll", "Want to send a funny YouTube clip in an iMessage or post a Short to your Instagram Story? Download the video as an MP4 using our tool. Once it finishes downloading in Safari, tap the Downloads icon, open the video, hit the iOS Share sheet, and select 'Save Video'. It instantly appears in your Photos app / Camera Roll."], ["Bypass Desktop iTunes Syncing", "Gone are the days of downloading music on your Mac, connecting a lightning cable, and waiting for iTunes to sync. With our web app, you can build your offline music library directly from your iPhone screen while riding the bus or laying in bed."], ["Optimized for Safari and WebKit", "Our frontend is specifically optimized for Apple's WebKit engine. The site is lightweight, ad-free, and respects iOS Dark Mode settings natively. The interface scales perfectly on the iPhone SE, iPhone 15 Pro Max, and every iPad in between, ensuring tap targets are large and accessible."], ["Install as an iOS Web App (PWA)", "For the ultimate native experience, you can install our converter directly to your home screen. Open our site in Safari, tap the 'Share' icon, scroll down, and tap 'Add to Home Screen'. Our icon will appear next to your other apps, launching in a fast, full-screen, chromeless window without the Safari address bar taking up space."], ["Create Custom Ringtones with GarageBand", "Want a custom ringtone from a YouTube video? Use our tool to download the audio as an M4A or WAV file to your Files app. Then, open GarageBand for iOS, import the audio file into a track, trim it to 30 seconds, and export it directly as an iOS Ringtone. No computer required!"], ["Play Audio in the Background", "Files downloaded via our tool can be played using the native iOS Files app or VLC for Mobile. Unlike the free YouTube app, which stops playing when you lock your screen, locally downloaded MP3s or M4As will continue playing in the background, allowing you to listen to podcasts while using other apps or with your phone in your pocket."], ["Format Comparison Table", "<div style=\"overflow-x:auto;\">\n      <table style=\"width:100%; border-collapse: collapse; text-align: left;\">\n        <tr style=\"border-bottom: 1px solid var(--border);\"><th style=\"padding: 8px;\">Format</th><th style=\"padding: 8px;\">Best iPhone Use Case</th><th style=\"padding: 8px;\">Where it Saves</th></tr>\n        <tr style=\"border-bottom: 1px solid var(--border);\"><td style=\"padding: 8px;\">MP4</td><td style=\"padding: 8px;\">Watching offline, iMessage sharing</td><td style=\"padding: 8px;\">Files App -> Camera Roll</td></tr>\n        <tr style=\"border-bottom: 1px solid var(--border);\"><td style=\"padding: 8px;\">M4A</td><td style=\"padding: 8px;\">Battery-efficient music listening</td><td style=\"padding: 8px;\">Files App / VLC</td></tr>\n        <tr style=\"border-bottom: 1px solid var(--border);\"><td style=\"padding: 8px;\">MP3</td><td style=\"padding: 8px;\">Universal audio, podcasts</td><td style=\"padding: 8px;\">Files App / VLC</td></tr>\n      </table>\n    </div>"], ["How to Use on iPhone", "1. Open the YouTube app, find a video, tap 'Share', and select 'Copy Link'. 2. Swipe up to go home and open Safari. 3. Navigate to our site and paste the link. 4. Choose your format (MP4 for video, M4A/MP3 for audio) and hit Convert. 5. Tap 'Download'. When prompted by Safari, tap 'Download' again. 6. Tap the blue down-arrow in Safari's address bar to access your file."]], "faqs": [["Do I need to jailbreak my iPhone to use this?", "No, absolutely not. Our tool works natively through the standard Safari browser included on every factory iPhone. No jailbreak or third-party profiles are required."], ["Can I add downloaded MP3s directly to the Apple Music app on my iPhone?", "Apple restricts direct imports into the native Apple Music app library from the iOS file system. You can play them in the Files app, or use a free app like VLC. To get them into Apple Music, you still need to sync them via a Mac or PC once."], ["Why did Safari ask for permission to download?", "Since iOS 13, Safari has a built-in download manager. It prompts you to confirm 'Do you want to download [filename]?' as a security measure. Simply tap Download to confirm."], ["Where do my downloads go?", "By default, Safari saves files to the 'Downloads' folder inside your iCloud Drive. You can find this by opening the blue 'Files' app on your iPhone. You can change this to 'On My iPhone' in Settings > Safari > Downloads."], ["How do I save a downloaded MP4 video to my Photos app?", "Open the Files app, tap the downloaded video to open it, tap the Share icon (square with an arrow pointing up) in the bottom corner, and tap 'Save Video'."], ["Does this work on iPad?", "Yes, the experience on iPadOS is identical, taking full advantage of the larger screen and the desktop-class Safari browser."], ["Can I download while on cellular data (4G/5G)?", "Yes, but be mindful of your data cap. Downloading a 1080p MP4 movie can use hundreds of megabytes of data. Audio files (MP3/M4A) use very little data."], ["Is the site safe from pop-ups and redirects?", "Yes. We have built a clean, premium interface. We do not use malicious pop-unders, fake 'update your iPhone' alerts, or spammy redirects common on other converter sites."], ["Why did the download fail when my screen locked?", "If you are downloading a very large file, iOS might suspend Safari's background network activity to save battery. It's best to keep the screen awake during the final file transfer phase."], ["Can I use Chrome on iOS instead of Safari?", "Yes, you can use Google Chrome or Firefox on iOS. They also have built-in download managers that will save the files to your device in a similar manner."]]}, "android-converter": {"sections": [["The Premier YouTube Converter for Android", "Android's open file system makes it the perfect platform for downloading and managing media. Our web-based Android YouTube Converter is specifically optimized to interface flawlessly with Google Chrome, Samsung Internet, and Brave browsers on Android. Whether you want to rip an MP3 for your commute or save a 1080p MP4 for offline viewing, our tool integrates seamlessly with your device without requiring an APK installation."], ["Direct Integration with Android Media Scanners", "Unlike iOS, Android has a global file system and a background Media Scanner. When you download an MP3 or MP4 using our tool, it drops straight into your Android 'Downloads' folder. Almost instantly, the Android OS detects the new file and populates it directly into your default Music Player, Gallery, or Google Photos app. It's completely frictionless."], ["No Sketchy APKs Required", "The Google Play Store frequently bans YouTube downloader apps, forcing users to sideload dangerous, ad-infested APKs from untrusted forums. Don't risk infecting your phone with malware. Our solution is 100% web-based. You get all the power of a dedicated downloader app with the security and sandboxing of your standard web browser."], ["Fast Background Downloading", "Android's Chrome download manager is incredibly robust. Once you hit 'Download' on our site, Chrome takes over the file transfer. You can immediately close the browser tab, lock your screen, or switch to another app\u2014the file will continue downloading securely in the background, complete with a progress bar in your notification shade."], ["Perfect for MicroSD Storage Expansion", "Many Android devices still feature MicroSD card slots. You can configure your browser to save downloads directly to your external SD card. Use our tool to download massive playlists or 4K MP4s and fill up your cheap external storage without eating into your phone's internal memory."], ["Install as a WebAPK (Progressive Web App)", "Get the native app experience safely. Open our site in Chrome, tap the three-dot menu, and select 'Install app' or 'Add to Home screen'. Android will generate a WebAPK, placing our icon in your app drawer. It launches instantly in full-screen mode, completely free of browser chrome, feeling exactly like a native app."], ["Set Custom Ringtones Instantly", "Android makes customization easy. Download a YouTube audio track using our MP3 converter. Then, simply go to your Android Settings > Sound & Vibration > Phone Ringtone, tap 'Add Ringtone', and select the downloaded MP3 from your files. You have a custom ringtone in seconds."], ["Supports Split-Screen Multitasking", "Power users love Android's multitasking capabilities. You can open the YouTube app on the top half of your screen and our converter site on the bottom half. Simply drag-and-drop or quickly copy/paste URLs between the two windows for ultra-fast, continuous downloading."], ["Format Comparison Table", "<div style=\"overflow-x:auto;\">\n      <table style=\"width:100%; border-collapse: collapse; text-align: left;\">\n        <tr style=\"border-bottom: 1px solid var(--border);\"><th style=\"padding: 8px;\">Format</th><th style=\"padding: 8px;\">Best Android Use Case</th><th style=\"padding: 8px;\">App Integration</th></tr>\n        <tr style=\"border-bottom: 1px solid var(--border);\"><td style=\"padding: 8px;\">MP4</td><td style=\"padding: 8px;\">Offline viewing, WhatsApp sharing</td><td style=\"padding: 8px;\">Gallery, Google Photos, VLC</td></tr>\n        <tr style=\"border-bottom: 1px solid var(--border);\"><td style=\"padding: 8px;\">MP3</td><td style=\"padding: 8px;\">Universal music, custom ringtones</td><td style=\"padding: 8px;\">Spotify Local Files, Poweramp</td></tr>\n        <tr style=\"border-bottom: 1px solid var(--border);\"><td style=\"padding: 8px;\">M4A</td><td style=\"padding: 8px;\">High-quality audio, podcasts</td><td style=\"padding: 8px;\">Samsung Music, Musicolet</td></tr>\n      </table>\n    </div>"], ["How to Download on Android", "1. Open the YouTube app and find your video. 2. Tap the 'Share' button beneath the video and select 'Copy link'. 3. Open Chrome or your preferred browser and navigate to our site. 4. Tap the input box and hit the 'Paste' button. 5. Choose MP3 or MP4 and select your quality. 6. Tap Convert, then tap Download. The file will save to your Downloads folder."]], "faqs": [["Is this better than downloading an app from the Play Store?", "Yes. Google bans legitimate YouTube downloaders from the Play Store. Any app you find there is likely a fake, filled with ads, or a privacy risk. Our web tool is safe, fast, and requires no permissions."], ["Where do the downloaded files go on my Android?", "By default, all Android browsers save files to the 'Downloads' folder on your internal storage. You can access them using the 'Files by Google', 'My Files' (Samsung), or any file manager app."], ["Will downloaded MP3s automatically show up in my music player?", "Yes. Android's Media Storage scanner routinely checks the Downloads folder. Within a few moments of downloading, the MP3 should appear in Samsung Music, Poweramp, Spotify Local, or YouTube Music (Device Files)."], ["Can I share the downloaded video on WhatsApp?", "Yes. Once the MP4 is downloaded to your device, you can attach it in WhatsApp, Telegram, or any other messaging app, provided the file size is under the app's sharing limit."], ["Why did Chrome warn me about downloading a file?", "Chrome sometimes shows a generic warning ('File might be harmful') when downloading certain media types, especially if you download many files quickly. Our MP3 and MP4 files are standard media files and are completely safe."], ["Does the site work on Samsung Internet browser?", "Yes, our site is thoroughly tested and fully compatible with Google Chrome, Samsung Internet, Firefox for Android, Brave, and Opera Touch."], ["How do I change the download location to my SD card?", "Open Chrome, tap the three dots (Menu) > Settings > Downloads. Here you can change the download location to your SD Card, or toggle 'Ask where to save files'. "], ["Can I download while on a phone call?", "Yes. The conversion happens on our cloud servers, and Chrome handles the file transfer in the background, completely independent of your cellular voice calls."], ["Do I need to root my Android phone for this?", "No root access is required. Our tool uses standard web technologies available on every non-rooted, factory Android device."], ["Are there annoying pop-up ads on the site?", "No. We specifically designed this platform to be clean and ad-free. You will not experience frustrating pop-unders, redirects, or fake 'Download Now' banners."]]}};
  if (contentMap[p.slug]) {
    p.sections = p.sections.concat(contentMap[p.slug].sections);
    if (!p.faqs) p.faqs = [];
    p.faqs = p.faqs.concat(contentMap[p.slug].faqs);
  }
});

function esc(s) { return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;"); }

function header() {
  return `<header class="site-header"><div class="container header-row"><a class="brand" href="/" aria-label="${BRAND} home">yt2mp3<span class="brand-dot">.lol</span></a><div class="header-actions"><button type="button" class="btn-supporter" aria-label="Support"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l2.5 6L21 9l-5 4.5L17.5 20 12 16.8 6.5 20 8 13.5 3 9l6.5-1L12 2z" fill="currentColor"/></svg><span class="s-label">Supporter</span></button><details class="lang-menu"><summary class="btn-lang" role="button" aria-label="Language"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8"/><path d="M3 12h18M12 3c3 3 3 15 0 18M12 3c-3 3-3 15 0 18" stroke="currentColor" stroke-width="1.5" fill="none"/></svg><span class="l-label">English</span><svg width="10" height="10" viewBox="0 0 12 12" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></summary><div class="lang-list" role="menu"><a role="menuitem" href="#" class="lang-active">English</a><a role="menuitem" href="#">العربية</a><a role="menuitem" href="#">বাংলা</a><a role="menuitem" href="#">Deutsch</a><a role="menuitem" href="#">Español</a><a role="menuitem" href="#">Filipino</a><a role="menuitem" href="#">Français</a><a role="menuitem" href="#">हिन्दी</a><a role="menuitem" href="#">Bahasa Indonesia</a><a role="menuitem" href="#">Italiano</a><a role="menuitem" href="#">日本語</a><a role="menuitem" href="#">한국어</a><a role="menuitem" href="#">Bahasa Melayu</a><a role="menuitem" href="#">မြန်မာ</a><a role="menuitem" href="#">Português</a><a role="menuitem" href="#">Русский</a><a role="menuitem" href="#">ภาษาไทย</a><a role="menuitem" href="#">Türkçe</a><a role="menuitem" href="#">اردو</a><a role="menuitem" href="#">Tiếng Việt</a></div></details><button type="button" class="btn-theme" id="theme-toggle" aria-label="Toggle theme" title="Toggle theme"><svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 14.5A8 8 0 019.5 4 8 8 0 1020 14.5z" fill="currentColor"/></svg><svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="4" fill="currentColor"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3M4.5 4.5l2 2M17.5 17.5l2 2M4.5 19.5l2-2M17.5 6.5l2-2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg></button></div></div></header>`;
}

function footer() {
  return `<footer class="site-footer"><div class="container"><nav class="footer-nav" aria-label="Footer primary"><a href="/youtube-to-mp4-converter">YouTube to MP4</a><a href="/youtube-playlist-downloader">Playlist Downloader</a><a href="/youtube-shorts-downloader">Shorts Downloader</a><a href="/youtube-multi-downloader">Multiple Download</a><a href="/how-to-install">How to Install</a><a href="/faq">FAQ</a><a href="/about">About</a><a href="/contact">Contact</a></nav><nav class="footer-nav footer-legal" aria-label="Footer legal"><a href="/copyright-claims">Copyright Claims</a><a href="/privacy-policy">Privacy Policy</a><a href="/terms-of-use">Terms of Use</a></nav><p class="footer-copy">&copy; <span id="year"></span> ${BRAND}. Not affiliated with YouTube or Google.</p></div></footer>`;
}

function converterCard(p) {
  const isMulti = p && p.slug === "youtube-multi-downloader";
  const inputHtml = isMulti 
    ? `<textarea id="yt-url" name="url" placeholder="Paste YouTube URLs here (one per line)" aria-label="Paste YouTube links" required autocomplete="off" spellcheck="false" rows="4" style="resize:vertical;"></textarea>`
    : `<input id="yt-url" name="url" type="text" inputmode="url" placeholder="Paste YouTube URL or search keywords" aria-label="Paste a YouTube link" required autocomplete="off" spellcheck="false">`;

  return `<div id="converter" class="converter-card" role="region" aria-label="YouTube converter">
  <h2 class="converter-title">YT2MP3 - YouTube to MP3</h2>
  <form id="convert-form" autocomplete="off" novalidate>
    <div class="url-wrap">
      ${inputHtml}
      ${!isMulti ? `<button type="button" id="paste-btn" aria-label="Paste from clipboard" title="Paste"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="8" y="3" width="8" height="4" rx="1" stroke="currentColor" stroke-width="1.8"/><path d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h12a2 2 0 002-2V7a2 2 0 00-2-2h-2" stroke="currentColor" stroke-width="1.8" fill="none"/></svg></button>` : ''}
    </div>
    <div class="controls-row">
      <div class="seg" role="tablist" aria-label="Output format"><button type="button" class="seg-btn active" role="tab" aria-selected="true" data-format="mp3">MP3</button><button type="button" class="seg-btn" role="tab" aria-selected="false" data-format="mp4">MP4</button></div>
      <label for="quality" class="sr-only">Quality</label>
      <select id="quality" class="select-pill" aria-label="Quality"></select>
      <details class="track-menu">
        <summary class="track-pill" role="button" aria-label="Audio track"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="9" y="3" width="6" height="12" rx="3" fill="currentColor"/><path d="M5 11a7 7 0 0014 0M12 18v3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg><span id="track-label">Origin</span><svg width="10" height="10" viewBox="0 0 12 12" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></summary>
        <div class="track-list" role="menu" style="min-width:200px;">
          <div class="track-search-wrap" style="padding:8px 12px;border-bottom:1px solid var(--border);">
            <input type="text" id="track-search" class="track-search" placeholder="Search languages..." aria-label="Search languages" style="width:100%;padding:6px;border:1px solid var(--border);border-radius:4px;background:var(--bg);color:var(--text);font-size:14px;">
          </div>
          <div class="track-scroll" style="max-height:220px;overflow-y:auto;padding:4px;">
            <button type="button" class="track-opt" data-track="" role="menuitem">Origin (default)</button>
            <button type="button" class="track-opt" data-track="en" role="menuitem">🇬🇧 English</button>
            <button type="button" class="track-opt" data-track="hi" role="menuitem">🇮🇳 Hindi</button>
            <button type="button" class="track-opt" data-track="en-IN" role="menuitem">🇮🇳 English (India)</button>
            <button type="button" class="track-opt" data-track="fr-CA" role="menuitem">🇨🇦 French (Canada)</button>
            <button type="button" class="track-opt" data-track="es-419" role="menuitem">🇲🇽 Spanish (LatAm)</button>
            <button type="button" class="track-opt" data-track="ar" role="menuitem">🇸🇦 Arabic</button>
            <button type="button" class="track-opt" data-track="ja" role="menuitem">🇯🇵 Japanese</button>
            <button type="button" class="track-opt" data-track="ko" role="menuitem">🇰🇷 Korean</button>
            <button type="button" class="track-opt" data-track="fr" role="menuitem">🇫🇷 French</button>
            <button type="button" class="track-opt" data-track="es" role="menuitem">🇪🇸 Spanish</button>
            <button type="button" class="track-opt" data-track="de" role="menuitem">🇩🇪 German</button>
            <button type="button" class="track-opt" data-track="it" role="menuitem">🇮🇹 Italian</button>
            <button type="button" class="track-opt" data-track="pt-BR" role="menuitem">🇧🇷 Portuguese (Brazil)</button>
            <button type="button" class="track-opt" data-track="pt" role="menuitem">🇵🇹 Portuguese</button>
            <button type="button" class="track-opt" data-track="ru" role="menuitem">🇷🇺 Russian</button>
            <button type="button" class="track-opt" data-track="zh-Hans" role="menuitem">🇨🇳 Chinese (Simplified)</button>
            <button type="button" class="track-opt" data-track="zh-Hant" role="menuitem">🇹🇼 Chinese (Traditional)</button>
            <button type="button" class="track-opt" data-track="vi" role="menuitem">🇻🇳 Vietnamese</button>
            <button type="button" class="track-opt" data-track="th" role="menuitem">🇹🇭 Thai</button>
            <button type="button" class="track-opt" data-track="id" role="menuitem">🇮🇩 Indonesian</button>
            <button type="button" class="track-opt" data-track="tl" role="menuitem">🇵🇭 Filipino</button>
            <button type="button" class="track-opt" data-track="tr" role="menuitem">🇹🇷 Turkish</button>
            <button type="button" class="track-opt" data-track="pl" role="menuitem">🇵🇱 Polish</button>
            <button type="button" class="track-opt" data-track="nl" role="menuitem">🇳🇱 Dutch</button>
            <button type="button" class="track-opt" data-track="sv" role="menuitem">🇸🇪 Swedish</button>
            <button type="button" class="track-opt" data-track="no" role="menuitem">🇳🇴 Norwegian</button>
            <button type="button" class="track-opt" data-track="da" role="menuitem">🇩🇰 Danish</button>
            <button type="button" class="track-opt" data-track="fi" role="menuitem">🇫🇮 Finnish</button>
            <button type="button" class="track-opt" data-track="el" role="menuitem">🇬🇷 Greek</button>
            <button type="button" class="track-opt" data-track="cs" role="menuitem">🇨🇿 Czech</button>
            <button type="button" class="track-opt" data-track="hu" role="menuitem">🇭🇺 Hungarian</button>
            <button type="button" class="track-opt" data-track="ro" role="menuitem">🇷🇴 Romanian</button>
            <button type="button" class="track-opt" data-track="bg" role="menuitem">🇧🇬 Bulgarian</button>
            <button type="button" class="track-opt" data-track="uk" role="menuitem">🇺🇦 Ukrainian</button>
            <button type="button" class="track-opt" data-track="he" role="menuitem">🇮🇱 Hebrew</button>
            <button type="button" class="track-opt" data-track="ms" role="menuitem">🇲🇾 Malay</button>
            <button type="button" class="track-opt" data-track="bn" role="menuitem">🇧🇩 Bengali</button>
            <button type="button" class="track-opt" data-track="ur" role="menuitem">🇵🇰 Urdu</button>
            <button type="button" class="track-opt" data-track="fa" role="menuitem">🇮🇷 Persian</button>
          </div>
        </div>
      </details>
      <div class="spacer"></div>
      <button id="convert-btn" type="submit">Convert</button>
    </div>
    <div id="status" class="status hidden" aria-live="polite"></div>
  </form>
</div>`;
}

function renderLandingPage(p) {
  const sectionsHtml = p.sections.map((s, i) =>
    `<section class="section${i % 2 ? " alt" : ""}"><div class="container"><h2>${esc(s[0])}</h2><p>${esc(s[1])}</p></div></section>`
  ).join("\n");
  const faqsHtml = p.faqs && p.faqs.length
    ? `<section class="section"><div class="container"><h2>FAQ</h2>${p.faqs.map(f => `<details><summary>${esc(f[0])}</summary><p>${esc(f[1])}</p></details>`).join("")}</div></section>`
    : "";
  const faqLd = p.faqs && p.faqs.length
    ? `<script type="application/ld+json">${JSON.stringify({ "@context": "https://schema.org", "@type": "FAQPage", mainEntity: p.faqs.map(f => ({ "@type": "Question", name: f[0], acceptedAnswer: { "@type": "Answer", text: f[1] } })) })}</script>`
    : "";
  const howToLd = ["faq", "about", "contact", "copyright-claims", "privacy-policy", "terms-of-use"].includes(p.slug) ? "" :
    `<script type="application/ld+json">${JSON.stringify({
      "@context": "https://schema.org",
      "@type": "HowTo",
      name: "How to convert using " + BRAND,
      step: [
        { "@type": "HowToStep", name: "Copy link", text: "Copy the video URL from your browser or app." },
        { "@type": "HowToStep", name: "Paste and select format", text: "Paste the link and choose your preferred format and quality." },
        { "@type": "HowToStep", name: "Download", text: "Click Convert and download the file." }
      ]
    })}</script>`;

  return `<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
<meta name="theme-color" content="#0b0d14" media="(prefers-color-scheme: dark)">
<meta name="theme-color" content="#f3f4f9" media="(prefers-color-scheme: light)">
<title>${esc(p.title)} - ${BRAND}</title>
<meta name="description" content="${esc(p.kicker)}">
<meta name="keywords" content="${esc(p.keywords)}">
<link rel="canonical" href="${SITE}/${p.slug}">
<meta property="og:title" content="${esc(p.title)}">
<meta property="og:description" content="${esc(p.kicker)}">
<meta property="og:type" content="website">
<meta property="og:url" content="${SITE}/${p.slug}">
<meta name="twitter:card" content="summary_large_image">
<meta name="robots" content="index,follow,max-image-preview:large">
<link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">
<link rel="stylesheet" href="/assets/style.css?v=2">
<script>(function(){try{var t=localStorage.getItem("tr-theme");if(t)document.documentElement.setAttribute("data-theme",t);}catch(e){}})();</script>
${faqLd}
${howToLd}
</head>
<body>
<a href="#converter" class="skip">Skip to converter</a>
${header()}
<main>
<section class="hero">
  <div class="container">
    <p style="margin:0 0 12px;font-size:14px;color:#9aa0b4"><a href="/">&larr; Home</a></p>
    <h1 style="text-align:center;margin:0 0 8px;font-size:clamp(24px,4vw,34px);letter-spacing:-.02em">${esc(p.h1)}</h1>
    <p style="text-align:center;color:#a3a8b8;max-width:620px;margin:0 auto 24px">${esc(p.kicker)}</p>
    ${converterCard(p)}
  </div>
</section>
${sectionsHtml}
${faqsHtml}
</main>
${footer()}
<script>window.__DEFAULT_FORMAT__=${JSON.stringify(p.defaultFormat)};window.__DEFAULT_QUALITY__=${JSON.stringify(p.defaultQuality)};</script>
<script src="/assets/app.js?v=2" defer></script>
</body>
</html>
`;
}

// Emit each page at web/<slug>/index.html for clean URLs on any static host.
for (const p of PAGES) {
  const dir = path.join(WEB, p.slug);
  fs.mkdirSync(dir, { recursive: true });
  fs.writeFileSync(path.join(dir, "index.html"), renderLandingPage(p));
  console.log("wrote", p.slug + "/index.html");
}

// Emit a sitemap.xml covering all SEO-visible URLs.
const urls = [
  { loc: "/", pri: "1.0", freq: "daily" },
  ...PAGES.filter(p => !["privacy-policy", "terms-of-use", "copyright-claims", "contact"].includes(p.slug))
    .map(p => ({ loc: "/" + p.slug, pri: ["youtube-to-mp4-converter", "youtube-shorts-downloader", "youtube-to-mp3-320kbps-converter"].includes(p.slug) ? "0.9" : "0.8", freq: "weekly" })),
  ...PAGES.filter(p => ["privacy-policy", "terms-of-use", "copyright-claims", "contact"].includes(p.slug))
    .map(p => ({ loc: "/" + p.slug, pri: "0.4", freq: "yearly" })),
];
const sitemap = `<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
${urls.map(u => `  <url><loc>${SITE}${u.loc}</loc><priority>${u.pri}</priority><changefreq>${u.freq}</changefreq></url>`).join("\n")}
</urlset>
`;
fs.writeFileSync(path.join(WEB, "sitemap.xml"), sitemap);
console.log("wrote sitemap.xml (" + urls.length + " URLs)");
